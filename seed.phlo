static orders {
	$variants = variant::records()
	$start = time() - 365 * 86400
	while (($start += between(3600 * 30, 3600 * 240)) < time()){
		$who = randItem(static::$customers)
		$age = time() - $start
		$status = $age > 86400 * 21 ? 'completed' : randItem(['new', 'paid', 'paid', 'sent'])
		$order = order::create (
			firstName: $who[0],
			lastName: $who[1],
			email: strtolower($who[0].dot.$who[1]).'@example.com',
			phone: chance(40) ? '+31 6 '.between(10000000, 99999999) : void,
			street: 'Demo Street',
			housenumber: (string)between(1, 240),
			zip: between(10000, 99999),
			city: $who[2],
			country: $who[3],
			status: $status,
			comment: chance(12) ? 'Please wrap as a gift.' : void,
			total: 0,
			shipping: chance(80) ? 'Standard (2-3 working days)' : 'Express (1 working day)',
			paymentMethod: randItem(['iDEAL', 'iDEAL', 'Creditcard', 'PayPal']),
			created: $start,
		)
		$total = 4.95
		foreach (randItem($variants, between(1, 3)) AS $variant){
			$qty = randItem([1, 1, 1, 2])
			$total += $qty * $variant->price
			$product = product::record(id: $variant->productId)
			order_variant::create (
				orderId: $order,
				variant: $variant,
				title: $product?->title,
				quantity: $qty,
				price: $variant->price,
			)
		}
		order::change('id=?', $order->id, total: round($total, 2))
	}
}

function chance(int $percentage) => mt_rand(1, 100) <= $percentage
function between(int $min, int $max) => mt_rand($min, $max)
function randItem(array $items, $amount = null){
	if ($amount === null) return $items[array_rand($items)]
	if ($amount === 1) return [$key = array_rand($items) => $items[$key]]
	return array_intersect_key($items, array_flip(array_rand($items, min($amount, count($items)))))
}

// ---- Product imagery: an elegant monogram card per product, plus a hover variant ----

static fontSerif => is_file($f = '/usr/share/fonts/truetype/dejavu/DejaVuSerif-Bold.ttf') ? $f : null
static fontSans => is_file($f = '/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf') ? $f : null

static color($im, $hex){
	$hex = ltrim($hex, '#')
	return imagecolorallocate($im, hexdec(substr($hex, 0, 2)), hexdec(substr($hex, 2, 2)), hexdec(substr($hex, 4, 2)))
}

static shade($hex, $factor){
	$hex = ltrim($hex, '#')
	$rgb = [hexdec(substr($hex, 0, 2)), hexdec(substr($hex, 2, 2)), hexdec(substr($hex, 4, 2))]
	return loop($rgb, fn($c) => max(0, min(255, (int)round($c * $factor))))
}

static saveImage($im, $dir, $token){
	$sub = $dir.substr($token, 0, 2)
	is_dir($sub) || mkdir($sub, 0775, true)
	ob_start()
	imagepng($im, null, 8)
	$data = ob_get_clean()
	file_put_contents($sub.slash.substr($token, 2).'.png', $data)
}

static wrap($font, $size, $text, $maxWidth){
	if (!$font) return [$text]
	$lines = []
	$line = void
	foreach (explode(space, $text) AS $word){
		$try = $line === void ? $word : $line.space.$word
		$box = imagettfbbox($size, 0, $font, $try)
		if ($box[2] - $box[0] > $maxWidth && $line !== void){
			$lines[] = $line
			$line = $word
		}
		else $line = $try
	}
	$line === void || $lines[] = $line
	return $lines
}

static centered($im, $font, $size, $y, $text, $color, $width = 800){
	if (!$font) return imagestring($im, 4, (int)(($width - strlen($text) * 8) / 2), $y - 10, $text, $color)
	$box = imagettfbbox($size, 0, $font, $text)
	imagettftext($im, $size, 0, (int)(($width - ($box[2] - $box[0])) / 2), $y, $color, $font, $text)
}

// The hero banner behind the page headers: a soft atelier gradient with a gold
// thread motif, written to www/hero.png (referenced from style.shop.phlo).
static heroBanner {
	$w = 1920
	$h = 1080
	$im = imagecreatetruecolor($w, $h)
	$top = [242, 236, 222]
	$bottom = [212, 199, 175]
	foreach (range(0, $h - 1) AS $y){
		$mix = $y / $h
		$color = imagecolorallocate($im, (int)($top[0] + ($bottom[0] - $top[0]) * $mix), (int)($top[1] + ($bottom[1] - $top[1]) * $mix), (int)($top[2] + ($bottom[2] - $top[2]) * $mix))
		imageline($im, 0, $y, $w, $y, $color)
	}
	$gold = imagecolorallocatealpha($im, 176, 141, 38, 90)
	$soft = imagecolorallocatealpha($im, 255, 255, 255, 100)
	imagesetthickness($im, 2)
	foreach (range(0, 14) AS $i){
		$x = $i * 160 - 240
		imageline($im, $x, $h, $x + 520, 0, $i % 3 === 0 ? $gold : $soft)
	}
	imagesetthickness($im, 1)
	imageellipse($im, (int)($w * 0.78), (int)($h * 0.3), 460, 460, $soft)
	imageellipse($im, (int)($w * 0.78), (int)($h * 0.3), 380, 380, $gold)
	ob_start()
	imagepng($im, null, 8)
	file_put_contents(www.'hero.png', ob_get_clean())
}

static productImage($title, $hex, $token, $variant = 0){
	$w = 800
	$h = 1000
	$im = imagecreatetruecolor($w, $h)
	$top = static::shade($hex, $variant ? 0.82 : 1.12)
	$bottom = static::shade($hex, $variant ? 0.38 : 0.62)
	foreach (range(0, $h - 1) AS $y){
		$mix = $y / $h
		$color = imagecolorallocate($im, (int)($top[0] + ($bottom[0] - $top[0]) * $mix), (int)($top[1] + ($bottom[1] - $top[1]) * $mix), (int)($top[2] + ($bottom[2] - $top[2]) * $mix))
		imageline($im, 0, $y, $w, $y, $color)
	}
	$gold = imagecolorallocate($im, 176, 141, 38)
	$soft = imagecolorallocatealpha($im, 255, 255, 255, 70)
	$ink = imagecolorallocatealpha($im, 255, 255, 255, 25)
	imagerectangle($im, 26, 26, $w - 27, $h - 27, $gold)
	imagerectangle($im, 34, 34, $w - 35, $h - 35, $soft)
	$serif = static::fontSerif()
	$sans = static::fontSans()
	static::centered($im, $sans, 15, 110, strtoupper('L\'Atelier Corseterie'), $soft, $w)
	imageline($im, 340, 135, $w - 340, 135, $gold)
	static::centered($im, $serif, 260, 620, strtoupper(substr($title, 0, 1)), $ink, $w)
	$y = 850
	foreach (static::wrap($sans, 22, strtoupper($title), 620) AS $line){
		static::centered($im, $sans, 22, $y, $line, $soft, $w)
		$y += 38
	}
	imageline($im, 360, $y + 4, $w - 360, $y + 4, $gold)
	static::saveImage($im, images, $token)
	$tw = 480
	$th = 600
	$tn = imagecreatetruecolor($tw, $th)
	imagecopyresampled($tn, $im, 0, 0, 0, 0, $tw, $th, $w, $h)
	static::saveImage($tn, thumbs, $token)
}

// ---- Interface translations: written to langs/<lang>.ini so the shop is fully ----
// ---- translated out of the box, without needing an OpenAI key.               ----

static langs {
	foreach (static::uiStrings() AS $lang => $pairs){
		$hashed = []
		foreach ($pairs AS $source => $translation) $hashed[%lang->hash('en', $source)] = $translation
		%lang->save($lang, $hashed)
	}
	return true
}

