static categories {
	$ids = []
	$sort = 0
	foreach (static::$categoryData AS $data) static::category($data, null, $sort, $ids)
	return $ids
}

static category($data, $parent, &$sort, &$ids){
	$category = category::create (
		parent: $parent,
		sort: ++$sort,
		uri: $data['uri'],
		title: $data['title'],
		sale: $data['sale'] ?? 0,
		text: $data['text'] ?? null,
	)
	$ids[$data['title']] = $category->id
	static::translations('category_translation', 'category', $category->id, $data)
	foreach ($data['children'] ?? [] AS $child) static::category($child, $category->id, $sort, $ids)
}

static translations($model, $key, $id, $data){
	foreach (['fr', 'es', 'de'] AS $lang){
		if (!isset($data[$lang])) continue
		[$title, $uri] = $data[$lang]
		$text = $data[$lang][2] ?? null
		$model::change($key.'=? AND lang=?', $id, $lang, title: $title, uri: $uri, text: $text)
	}
}

