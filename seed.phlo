@ summary: Demo data seeder for the Couture webshop. Rebuilds the SQLite schema, fills the
@          catalogue (categories, products, variants, stock, translations in en/fr/es/de),
@          generates the product imagery, spreads a year of demo orders over the shop and
@          writes the fr/es/de interface translations to langs/.
@          Run: php www/app.php seed::run

static run {
	set_time_limit(300)
	mt_srand(20260723)
	static::clearUploads()
	static::heroBanner()
	static::tables()
	$categoryIds = static::categories()
	static::products($categoryIds)
	static::orders()
	static::langs()
	return 'Seeded: '.category::recordCount().' categories, '.product::recordCount().' products, '.variant::recordCount().' variants, '.order::recordCount().' orders'
}

// Previous runs used different random tokens, so stale imagery piles up unless cleared.
static clearUploads {
	foreach ([images, thumbs] AS $dir){
		foreach (glob($dir.'*/*') ?: [] AS $file) is_file($file) && unlink($file)
		foreach (glob($dir.'*', GLOB_ONLYDIR) ?: [] AS $sub) @rmdir($sub)
	}
}

static tables {
	$db = %SQLite(data.'shop.db')
	foreach (['order_variants', 'orders', 'variant_stock', 'variants', 'product_images', 'product_translations', 'category_products', 'category_translations', 'products', 'categories'] AS $table) $db->query("DROP TABLE IF EXISTS $table")
	$db->query('CREATE TABLE categories (id INTEGER PRIMARY KEY AUTOINCREMENT, parent INTEGER, sort INTEGER NOT NULL DEFAULT 0, uri TEXT NOT NULL, title TEXT NOT NULL, sale INTEGER NOT NULL DEFAULT 0, text TEXT)')
	$db->query('CREATE TABLE category_translations (id INTEGER PRIMARY KEY AUTOINCREMENT, category INTEGER NOT NULL, lang TEXT NOT NULL, uri TEXT, title TEXT, text TEXT)')
	$db->query('CREATE TABLE category_products (category INTEGER NOT NULL, product INTEGER NOT NULL)')
	$db->query('CREATE TABLE products (id INTEGER PRIMARY KEY AUTOINCREMENT, sku TEXT, uri TEXT NOT NULL, title TEXT NOT NULL, text TEXT, color TEXT, material TEXT, active INTEGER NOT NULL DEFAULT 1, created INTEGER, changed INTEGER)')
	$db->query('CREATE TABLE product_translations (id INTEGER PRIMARY KEY AUTOINCREMENT, product INTEGER NOT NULL, lang TEXT NOT NULL, uri TEXT, title TEXT, text TEXT)')
	$db->query('CREATE TABLE product_images (id INTEGER PRIMARY KEY AUTOINCREMENT, product INTEGER NOT NULL, sort INTEGER NOT NULL DEFAULT 1, name TEXT, name_token TEXT)')
	$db->query('CREATE TABLE variants (id INTEGER PRIMARY KEY AUTOINCREMENT, product INTEGER NOT NULL, sku TEXT, size TEXT, remarks TEXT, priceCost REAL NOT NULL DEFAULT 0, priceOld REAL NOT NULL DEFAULT 0, price REAL NOT NULL DEFAULT 0, active INTEGER NOT NULL DEFAULT 1)')
	$db->query('CREATE TABLE variant_stock (id INTEGER PRIMARY KEY AUTOINCREMENT, variant INTEGER NOT NULL, location TEXT, level INTEGER NOT NULL DEFAULT 0)')
	$db->query('CREATE TABLE orders (id INTEGER PRIMARY KEY AUTOINCREMENT, firstName TEXT, lastName TEXT, email TEXT, phone TEXT, street TEXT, housenumber TEXT, zip TEXT, city TEXT, country TEXT, status TEXT, comment TEXT, total REAL, shipping TEXT, paymentMethod TEXT, created INTEGER)')
	$db->query('CREATE TABLE order_variants (id INTEGER PRIMARY KEY AUTOINCREMENT, orderId INTEGER NOT NULL, variant INTEGER, title TEXT, quantity INTEGER NOT NULL DEFAULT 1, price REAL)')
}

