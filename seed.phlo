static products($categoryIds){
	$db = %SQLite(data.'shop.db')
	$now = time()
	foreach (static::$productData AS $index => $data){
		$product = product::create (
			sku: $data['sku'],
			uri: $data['uri'],
			title: $data['title'],
			text: $data['text'],
			color: $data['color'],
			material: $data['material'],
			active: 1,
			created: $now - (count(static::$productData) - $index) * 86400 * 9 - between(0, 80000),
		)
		static::translations('product_translation', 'product', $product->id, $data)
		foreach ($data['cats'] AS $cat) isset($categoryIds[$cat]) && $db->create('category_products', category: $categoryIds[$cat], product: $product->id)
		foreach ($data['variants'] AS $n => $v){
			$variant = variant::create (
				product: $product->id,
				sku: $data['sku'].dash.($n + 1),
				size: $v[0],
				remarks: void,
				priceCost: round($v[1] * 0.45, 2),
				priceOld: $v[2] ?? 0,
				price: $v[1],
				active: 1,
			)
			variant_stock::create(variant: $variant->id, location: 'Warehouse', level: between(0, 24))
			chance(40) && variant_stock::create(variant: $variant->id, location: 'Atelier', level: between(0, 6))
		}
		foreach ([1, 2] AS $sort){
			$token = token(20)
			static::productImage($data['title'], $data['hex'], $token, $sort - 1)
			product_image::create(product: $product->id, sort: $sort, name: $data['uri'].dash.$sort.'.png', name_token: $token)
		}
	}
}

